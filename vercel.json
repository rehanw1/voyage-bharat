{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "GEMINI_API_KEY": "@GEMINI_API_KEY",
    "GEMINI_MODEL": "@GEMINI_MODEL"
  }
}
